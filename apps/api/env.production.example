# Variáveis de produção — configurar no Railway manualmente
# NÃO commitar este arquivo com valores reais

NODE_ENV=production

# MySQL Railway
MYSQL_URL=mysql://root:SUA_SENHA@gondola.proxy.rlwy.net:14421/railway

# Redis Railway
REDIS_URL=redis://default:SUA_SENHA@gondola.proxy.rlwy.net:57609

